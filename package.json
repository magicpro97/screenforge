{
  "name": "screenforge",
  "version": "1.1.0",
  "description": "📱 App Store Asset Generator CLI — icons, splash screens, device frames, ASO metadata from your terminal",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "screenforge": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "app-store",
    "screenshots",
    "icons",
    "splash-screen",
    "aso",
    "metadata",
    "cli",
    "mobile",
    "ios",
    "android",
    "device-frame"
  ],
  "author": "magicpro97",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicpro97/screenforge.git"
  },
  "homepage": "https://github.com/magicpro97/screenforge#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "ora": "^8.2.0",
    "sharp": "^0.33.5",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
